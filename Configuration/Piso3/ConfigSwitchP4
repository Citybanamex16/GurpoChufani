#

! Creación de la BD de cuentas autorizadas para acceder
username CEO privilege 15 secret tc2006b
username CIT privilege 15 secret tc2006b

ip domain name Chufani.com.mx

crypto key generate rsa
yes
1024

! Control de acceso por consola y acceso remoto
line console 0
  login local
  exec-timeout 2
  logging sync

! Maximo numero de line virtual que se pueden poner son 16
line vty 0 2
  login local
  exec-timeout 2
  transport input ssh
  logging sync

!================ Fin de Configuración General =====================
!=== Parámetros de configuración para manejo de VLANs ====
!Implementar el protocolo VTP
!vtp domain NAME
!vtp mode [server | client]
!vtp password Palabra

vtp domain Chufani.com.mx
vtp mode server
vtp password TC2006b


!1) Creación de VLANs
vlan 10
  name IoTDiseno

vlan 20
  name IoTOficina

vlan 30
  name Renders

vlan 40
  name AreaDisenoA

vlan 50
  name AreaDisenoB

vlan 60
  name VisitantesP1

vlan 70
  name VisitantesP4

vlan 80
  name VisitantesP3

vlan 90
  name Directores

vlan 100
  name IoTDirectores

vlan 110
  name Ventas

vlan 120
  name Presupuestos

vlan 130
  name Gestion

vlan 140
  name ServiciosP3

!No se asigna
!2) Asignación de puertos a las VLANs
!interface range INTERFACE_ID
!description TEXTO_LIBRE
!switchport mode access
!switchport access vlan VID
!no shutdown

!3) Definición de Truncales
interface range G1/1/1
  description Puerto TRUNK
  switchport mode trunk
  no shutdown

!4) Asignación de la IP de Gestión
interface vlan 911
  description IP de gestion remota (SSH)
  ip address 172.18.5.136 255.255.255.192
  no shutdown

ip default-gateway 172.18.5.190

!=============== Fin Config. Switch Central ============