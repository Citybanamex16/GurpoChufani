#

! Creación de la BD de cuentas autorizadas para acceder
username CEO privilege 15 secret tc2006b
username CIT privilege 15 secret tc2006b

ip domain name chuffani.com.mx

crypto key generate rsa
yes
1024

! Control de acceso por consola y acceso remoto
line console 0
  login local
  exec-timeout 2
  logging sync

! Maximo numero de line virtual que se pueden poner son 16
line vty 0 2
  login local
  exec-timeout 2
  transport input ssh
  logging sync

!================ Fin de Configuración General =====================

!=== Parámetros de configuración para manejo de VLANs ====
! Implementar el protocolo VTP
! vtp domain NAME
! vtp mode [server | client]
! vtp password Palabra

vtp domain chuffani.com.mx
vtp mode client
vtp password TC2006b

! No se crean VLANS
!1) Creación de VLANs

!2) Asignación de puertos a las VLANs
!interface range INTERFACE_ID
!description TEXTO_LIBRE
!switchport mode access
!switchport access vlan VID
!no shutdown

interface range Gig1/0/2-4
  description Puerto de la VLAN Area de Seguridad
  switchport mode access
  switchport access vlan 100
  no shutdown
exit

interface range Gig1/0/5-8
  description Puerto de la VLAN Area de Visitantes P1
  switchport mode access
  switchport access vlan 60
  no shutdown
exit

!4) Asignación de la IP de Gestión
interface vlan 911
  description IP de gestion remota (SSH)
  ip address 172.18.5.187 255.255.255.192
  no shutdown

!Puerto TRUNK
interface Gig1/1/1-2
  description Enlace Troncal hacia S-CoreP3
  switchport trunk encapsulation dot1q
  switchport mode trunk
  no shutdown
exit

ip default-gateway 172.18.5.129
!=============== Fin Config. Switch Multilayer Enclosure P1 ============