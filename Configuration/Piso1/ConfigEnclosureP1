!=============== Config Switch Enclosure P1 ============
!=============== Config Switch Servidores ============
!================ Configuración General ===================
! Entrar al modo EXEC
enable

! Establecer fecha y hora
! clock set 13:20:00 Jun 1 2026

! Configuración de los parámetros la terminal
configure terminal

hostname S-EnclocureP1

! Evitar que si existe un error en un comando se active la búsqueda por DNS de la solución
no ip domain lookup

banner motd #

